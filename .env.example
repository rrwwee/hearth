# `npm start` and `npm run demo` are safe and require no configuration.
# These values are only needed when the web server reaches a real agent.
HEARTH_MODE=live
HEARTH_BIND=127.0.0.1
PORT=4173
HEARTH_AGENT_MODE=ssh
HEARTH_HOST=pi-dashboard
HEARTH_AGENT=/home/pi/hearth/dashboard_agent.py
HEARTH_STATE_DIR=/home/pi/.local/state/hearth
HEARTH_CONFIG_DIR=/home/pi/.config/hearth

# Optional credential actions for a cluster reached through a private VPN.
HEARTH_CLUSTER_PRINCIPAL=researcher@EXAMPLE.EDU
HEARTH_CLUSTER_JUMP=cluster-jump
HEARTH_CLUSTER_PROBE_HOST=cluster-jump.example.invalid
HEARTH_VPN_HELPER=/home/pi/hearth/start-vpn-from-stdin.sh
