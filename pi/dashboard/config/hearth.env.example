# Copy to ~/Code/dashboard/config/hearth.env and replace every example value.
HEARTH_MODE=live
HEARTH_BIND=127.0.0.1
PORT=4173
HEARTH_AGENT_MODE=local
HEARTH_AGENT=/home/pi/Code/dashboard/dashboard_agent.py
HEARTH_BASE_DIR=/home/pi/Code/dashboard
HEARTH_STATE_DIR=/home/pi/Code/dashboard/state
HEARTH_CONFIG_DIR=/home/pi/Code/dashboard/config

HEARTH_LAN_CIDR=192.0.2.0/24

HEARTH_CLUSTER_USER=researcher
HEARTH_CLUSTER_PRINCIPAL=researcher@EXAMPLE.EDU
HEARTH_CLUSTER_JUMP=cluster-jump
HEARTH_CLUSTER_JUMP_HOST=cluster-jump.example.invalid
HEARTH_CLUSTER_HOST=compute
HEARTH_CLUSTER_HOST_NAME=compute.internal.example
HEARTH_CLUSTER_PROBE_HOST=cluster-jump.example.invalid
HEARTH_SSH_IDENTITY=/home/pi/.ssh/hearth_cluster

HEARTH_VPN_HOST=vpn.example.invalid
HEARTH_VPN_PORT=443
HEARTH_VPN_USER=researcher
HEARTH_VPN_ROUTES="198.51.100.0/24 203.0.113.0/24"
HEARTH_NTFY_TAILSCALE_PORT=8443

HEARTH_KERBEROS_REALM=EXAMPLE.EDU
HEARTH_KERBEROS_DOMAIN=example.edu
HEARTH_KERBEROS_KDCS="kdc1.example.invalid kdc2.example.invalid"
HEARTH_KERBEROS_ADMIN_SERVER=kdc1.example.invalid
